    "build": "tsdown"
  },
  "dependencies": {
    "@nuxt/kit": "workspace:*",
    "consola": "^3.4.2",
    "defu": "^6.1.7",
    "escape-string-regexp": "^5.0.0",
    "exsolve": "^1.0.8",
    "get-port-please": "^3.2.0",
    "magic-string": "^0.30.21",
    "mlly": "^1.8.2",
    "pathe": "^2.0.3",
    "seroval": "^1.5.4",
    "std-env": "^4.1.0",
    "ufo": "^1.6.4",
    "unenv": "^2.0.0-rc.24",
    "vue-bundle-renderer": "^2.2.0"
  },
  "peerDependencies": {
    "@nasti-toolchain/nasti": "^2.0.1",
    "nuxt": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/schema": "workspace:*",
    "tsdown": "0.22.2",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": ">=20.19.0"
  }
