{
  "name": "@nuxt/nasti-builder",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt/nuxt.git",
    "directory": "packages/nasti"
  },
  "description": "Nasti (Rolldown) bundler for Nuxt",
  "homepage": "https://nuxt.com",
  "license": "MIT",
  "type": "module",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "imports": {
    "#builder": "./builder.mjs",
    "#nasti-node": "./dist/nasti-node.mjs",
    "#nasti-node-entry": "./dist/nasti-node-entry.mjs",
    "#nasti-node-runner": "./dist/nasti-node-runner.mjs"
  },
  "files": [
    "builder.d.ts",
    "builder.mjs",
    "dist"
  ],
  "scripts": {
