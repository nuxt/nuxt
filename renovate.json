{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>nuxt/renovate-config-nuxt",
    ":pinDevDependencies",
    ":widenPeerDependencies"
  ],
  "baseBranches": [
    "main",
    "4.x",
    "3.x"
  ],
  "ignoreDeps": [
    "node",
    "npm"
  ],
  "minimumReleaseAge": "1 day",
  "packageRules": [
    {
      "groupName": "webpack",
      "matchPackageNames": [
        "/webpack/",
        "/-loader/"
      ]
    },
    {
      "groupName": "vitest",
      "matchPackageNames": [
        "vitest",
        "/^@vitest//"
      ]
    },
    {
      "groupName": "webpack",
      "matchPackageNames": [
        "webpack"
      ]
    },
    {
      "matchBaseBranches": [
        "main",
        "4.x",
        "3.x"
      ],
      "ignoreDeps": [
        "nitro",
        "h3",
        "nuxt",
        "nuxt3",
        "@nuxt/kit"
      ]
    },
    {
      "matchBaseBranches": [
        "4.x",
        "3.x"
      ],
      "groupName": "all dependencies",
      "groupSlug": "all",
      "matchPackageNames": [
        "*"
      ]
    },
    {
      "groupName": "rolldown",
      "groupSlug": "rolldown",
      "matchPackageNames": [
        "rolldown",
        "obuild"
      ]
    },
    {
      "matchPackageNames": [
        "@nuxt/**"
      ],
      "minimumReleaseAge": "0"
    }
  ],
  "vulnerabilityAlerts": {
    "postUpdateOptions": [
      "pnpmDedupe"
    ],
    "groupName": "all dependencies",
    "groupSlug": "all"
  }
}
