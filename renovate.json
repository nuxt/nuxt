{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>nuxt/renovate-config-nuxt",
    ":pinDevDependencies",
    ":widenPeerDependencies"
  ],
  "baseBranchPatterns": [
    "main",
    "4.x",
    "3.x"
  ],
  "ignoreDeps": [
    "node",
    "npm"
  ],
  "packageRules": [
    {
      "groupName": "webpack",
      "matchPackageNames": [
        "/webpack/",
        "/-loader/"
      ]
    },
    {
      "groupName": "vitest",
      "matchPackageNames": [
        "vitest",
        "/^@vitest//"
      ]
    },
    {
      "matchBaseBranches": [
        "main",
        "4.x",
        "3.x"
      ],
      "ignoreDeps": [
        "nuxt",
        "nuxt3",
        "@nuxt/kit"
      ]
    },
    {
      "matchBaseBranches": [
        "4.x",
        "3.x"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor",
        "pin",
        "digest",
        "lockFileMaintenance"
      ],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-non-major",
      "matchPackageNames": [
        "*"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "postUpdateOptions": [
      "pnpmDedupe"
    ]
  }
}
